# Copy this file to .env, fill in the key, then run 9xf.
# The harness reads .env from the current working directory and the run folder.
# You can also export it manually before running 9xf:
#   cp .env.example .env
#   set -a; source .env; set +a
#
# NVIDIA cloud inference is used by nvidia/<provider>/<model> configs, including:
#   nvidia/moonshotai/kimi-k2.6
#   nvidia/qwen/qwen3.5-122b-a10b
NVIDIA_API_KEY=nvapi-your-key-here

# Run the cloud benchmark:
#   python3 -m ninexf bench run thesis --out bench_out
